# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Claude auth — set EXACTLY ONE:
#   ANTHROPIC_API_KEY      → pay-as-you-go console credits
#   CLAUDE_CODE_OAUTH_TOKEN → Claude Pro/Max subscription (mint via: claude setup-token)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=
# Repos the bot may read (absolute paths to your local clones)
BACKEND_PATH=/path/to/backend-repo
FRONTEND_PATH=/path/to/frontend-repo
# Trello (human-gated bug tickets)
TRELLO_KEY=...
TRELLO_TOKEN=...
TRELLO_LIST_ID=...
# Optional
SESSIONS_FILE=./sessions.json
# Optional — append your own domain knowledge (schema names, routing docs,
# product jargon) to the system prompt. Keep this file OUT of version control.
# DOMAIN_PROMPT_FILE=./prompts/domain.local.md
# Optional — read-only reporting database. Set all five to enable query_reports_db.
# REPORTS_DB_SERVER=your-db-host
# REPORTS_DB_PORT=1433
# REPORTS_DB_NAME=YOUR_REPORTING_DB
# REPORTS_DB_USER=readonly_user
# REPORTS_DB_PASSWORD=...
